# ========== Polymarket 設定 ==========
POLY_PRIVATE_KEY=0x...your-private-key...
POLY_FUNDER_ADDRESS=0x...your-wallet-address...
POLY_SIGNATURE_TYPE=0
POLY_CHAIN_ID=137

# ========== LLM API キー ==========
# LiteLLM が環境変数から自動読み込み
# 使用するプロバイダーのキーのみ設定すればOK

# Anthropic (直接) - 推奨
ANTHROPIC_API_KEY=sk-ant-api03-xxx

# OpenAI (直接)
# OPENAI_API_KEY=sk-xxx

# OpenRouter (複数モデル経由)
# OPENROUTER_API_KEY=sk-or-v1-xxx

# Groq (高速推論、無料枠あり)
# GROQ_API_KEY=gsk_xxx

# ========== モデル一覧 ==========
# python main.py models で確認
#
# 最新 Anthropic:
#   claude-opus-4.6    - 最高性能 ($5/MTok)
#   claude-sonnet-4.6  - バランス ($3/MTok)
#   claude-haiku-4.5   - 最速・低コスト ($1/MTok) ← デフォルト
#
# OpenAI:
#   gpt-4o, gpt-4o-mini
#
# OpenRouter経由:
#   or/claude-haiku, or/claude-sonnet, or/llama-70b
#
# Groq (高速):
#   groq/llama-70b, groq/llama-8b
