# Polymarket 設定
POLY_PRIVATE_KEY=0x...your-private-key...
POLY_FUNDER_ADDRESS=0x...your-wallet-address...
POLY_SIGNATURE_TYPE=0
POLY_CHAIN_ID=137

# ========== LLM API (LiteLLM) ==========
# 使用するプロバイダーのAPIキーを設定

# Anthropic (直接)
ANTHROPIC_API_KEY=sk-ant-xxx

# OpenAI (直接)
# OPENAI_API_KEY=sk-xxx

# OpenRouter (複数モデル経由)
# OPENROUTER_API_KEY=sk-or-v1-xxx

# Groq (高速推論)
# GROQ_API_KEY=gsk_xxx

# ========== モデル選択 ==========
# 利用可能なモデル (analyst/llm_analyst.py 参照):
#   claude-haiku    → claude-3-haiku-20240307
#   claude-sonnet   → claude-sonnet-4-20250514
#   gpt-4o-mini     → gpt-4o-mini
#   or-haiku        → openrouter/anthropic/claude-3-haiku
#   llama-70b       → groq/llama-3.1-70b-versatile
