# Polymarket 設定
POLY_PRIVATE_KEY=0x...your-private-key...
POLY_FUNDER_ADDRESS=0x...your-wallet-address...

# signature_type:
# 0 = EOA/MetaMask (標準ウォレット)
# 1 = Email/Magic wallet
# 2 = Browser wallet proxy
POLY_SIGNATURE_TYPE=0

# Polygon Chain ID (mainnet = 137)
POLY_CHAIN_ID=137

# LLM API (分析用)
# OpenRouter (推奨 - 安い)
OPENROUTER_API_KEY=sk-or-v1-xxx

# または OpenAI
# OPENAI_API_KEY=sk-xxx
